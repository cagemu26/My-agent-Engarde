DATABASE_URL=postgresql://postgres:postgres@db:5432/fencing_ai
REDIS_URL=redis://redis:6379/0
CHROMA_PERSIST_DIR=./data/chroma
KB_DATA_DIR=./knowledge
KB_COLLECTION=fencing_knowledge

RAG_ENABLED=true
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.25
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=220
RAG_EMBED_BATCH_SIZE=16

QIANFAN_API_BASE=https://qianfan.baidubce.com/v2/embeddings
QIANFAN_BEARER_TOKEN=
QIANFAN_EMBED_MODEL=qwen3-embedding-4b

MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# JWT Settings
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
