DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fencing_ai
REDIS_URL=redis://localhost:6379/0

CHROMA_PERSIST_DIR=./data/chroma
KB_DATA_DIR=./knowledge
KB_COLLECTION=fencing_knowledge
VIDEO_UPLOAD_DIR=./data/videos
POSE_LANDMARKER_MODEL_PATH=./data/models/pose_landmarker_heavy.task
POSE_LANDMARKER_MODEL_URL=https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_heavy/float16/1/pose_landmarker_heavy.task

RAG_ENABLED=true
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.25
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=220
RAG_EMBED_BATCH_SIZE=16

QIANFAN_API_BASE=https://qianfan.baidubce.com/v2/embeddings
QIANFAN_BEARER_TOKEN=
QIANFAN_EMBED_MODEL=qwen3-embedding-4b

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# JWT Settings
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MIN_SECRET_KEY_LENGTH=32

# Email
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
FRONTEND_PUBLIC_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Engarde AI <noreply@engarde.ai>

# Auth rate limiting
RATE_LIMIT_ENABLED=true
AUTH_REGISTER_IP_RATE_LIMIT=10
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_LOGIN_IP_RATE_LIMIT=20
AUTH_LOGIN_EMAIL_RATE_LIMIT=10
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_RESEND_VERIFICATION_IP_RATE_LIMIT=10
AUTH_RESEND_VERIFICATION_EMAIL_RATE_LIMIT=5
AUTH_RESEND_VERIFICATION_WINDOW_SECONDS=3600
AUTH_VERIFY_EMAIL_IP_RATE_LIMIT=60
AUTH_VERIFY_EMAIL_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_IP_RATE_LIMIT=10
AUTH_PASSWORD_RESET_EMAIL_RATE_LIMIT=5
AUTH_PASSWORD_RESET_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_CONFIRM_IP_RATE_LIMIT=20
AUTH_PASSWORD_RESET_CONFIRM_WINDOW_SECONDS=3600

# CORS can be a JSON array or comma-separated list
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
