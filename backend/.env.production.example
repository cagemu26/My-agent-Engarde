DATABASE_URL=sqlite:////app/data/db/app.db
# Optional: if Redis is unavailable, the app falls back to in-memory rate limiting.
REDIS_URL=redis://127.0.0.1:6379/0

STORAGE_PROVIDER=cos
LOCAL_STORAGE_ROOT=/app/data/storage
LOCAL_STORAGE_BUCKET=local-bucket
LOCAL_TEMP_DIR=/tmp/engarde-ai

COS_BUCKET=engarde-1250000000
COS_REGION=ap-nanjing
COS_APP_ID=1250000000
COS_SECRET_ID=replace-with-cos-secret-id
COS_SECRET_KEY=replace-with-cos-secret-key
COS_KEY_PREFIX=prod
COS_RAW_PREFIX=raw
COS_DERIVED_PREFIX=derived
COS_STS_EXPIRE_SECONDS=900
COS_SIGNED_URL_EXPIRE_SECONDS=900

CDN_ENABLED=true
CDN_STATIC_BASE_URL=https://static.example.com
CDN_MEDIA_BASE_URL=https://media.example.com
CDN_MEDIA_SIGN_KEY=replace-with-cdn-sign-key
CDN_MEDIA_SIGN_EXPIRE_SECONDS=600
CDN_MEDIA_ANTI_HOTLINK_ENABLED=true

CHROMA_PERSIST_DIR=/app/data/chroma
KB_DATA_DIR=/app/knowledge
KB_COLLECTION=fencing_knowledge
VIDEO_UPLOAD_DIR=/app/data/videos
POSE_LANDMARKER_MODEL_PATH=/app/data/models/pose_landmarker_heavy.task
POSE_LANDMARKER_MODEL_URL=https://storage.googleapis.com/mediapipe-models/pose_landmarker/pose_landmarker_heavy/float16/1/pose_landmarker_heavy.task

RAG_ENABLED=true
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.25
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=220
RAG_EMBED_BATCH_SIZE=16
EMBEDDING_PROVIDER=auto
EMBEDDING_TIMEOUT_SECONDS=20.0

QIANFAN_API_BASE=https://qianfan.baidubce.com/v2/embeddings
QIANFAN_BEARER_TOKEN=replace-with-production-token
QIANFAN_EMBED_MODEL=qwen3-embedding-4b

BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
BAILIAN_API_KEY=replace-with-bailian-api-key
BAILIAN_EMBED_MODEL=text-embedding-v4
BAILIAN_EMBED_DIMENSIONS=1024

MINIMAX_API_KEY=replace-with-production-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_CONTEXT_WINDOW_TOKENS=204800
LLM_MAX_COMPLETION_TOKENS=10240
LLM_MAX_CONTEXT_CHARS=180000
LLM_MAX_SINGLE_MESSAGE_CHARS=40000
LLM_MAX_TOTAL_MESSAGES_CHARS=120000
LLM_MAX_SESSION_HISTORY_MESSAGES=80

SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MIN_SECRET_KEY_LENGTH=32

REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
FRONTEND_PUBLIC_URL=https://app.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=Engarde AI <noreply@example.com>

RATE_LIMIT_ENABLED=true
AUTH_REGISTER_IP_RATE_LIMIT=10
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_LOGIN_IP_RATE_LIMIT=20
AUTH_LOGIN_EMAIL_RATE_LIMIT=10
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_RESEND_VERIFICATION_IP_RATE_LIMIT=10
AUTH_RESEND_VERIFICATION_EMAIL_RATE_LIMIT=5
AUTH_RESEND_VERIFICATION_WINDOW_SECONDS=3600
AUTH_VERIFY_EMAIL_IP_RATE_LIMIT=60
AUTH_VERIFY_EMAIL_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_IP_RATE_LIMIT=10
AUTH_PASSWORD_RESET_EMAIL_RATE_LIMIT=5
AUTH_PASSWORD_RESET_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_CONFIRM_IP_RATE_LIMIT=20
AUTH_PASSWORD_RESET_CONFIRM_WINDOW_SECONDS=3600

CORS_ORIGINS=["https://app.example.com"]
