# Option A: leave empty to use same-origin API routes through reverse proxy.
NEXT_PUBLIC_API_URL=

# Option B: set to explicit backend public URL.
# NEXT_PUBLIC_API_URL=https://api.example.com

# Optional: static CDN domain for Next production assets.
# Leave this empty unless the CDN/static domain is fully ready:
# 1. the static domain certificate is valid,
# 2. fonts/static files return Access-Control-Allow-Origin,
# 3. the CDN forwards or preserves required response headers,
# 4. the CDN cache has been purged after a new frontend build.
# NEXT_PUBLIC_CDN_STATIC_BASE_URL=https://static.example.com
